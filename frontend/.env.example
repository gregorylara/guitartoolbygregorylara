# Frontend environment variables

# Firebase Configuration
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_auth_domain
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_storage_bucket
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Stripe Configuration
VITE_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
VITE_STRIPE_PRICE_MONTHLY=your_price_id_monthly
VITE_STRIPE_PRICE_ANNUAL=your_price_id_annual

# Backend API
# Set VITE_API_BASE to your Hostinger server URL after deploying server/
# Example: VITE_API_BASE=https://api.yourdomain.com
VITE_API_BASE=https://api.yourdomain.com
